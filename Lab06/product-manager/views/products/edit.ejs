<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | ShopManager</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('../partials/flash') %>

  <nav class="navbar">
    <a href="/" class="nav-brand">
      <span class="brand-icon">◈</span>
      <span>ShopManager</span>
    </a>
    <div class="nav-actions">
      <a href="/" class="nav-link">← Quay lại</a>
    </div>
  </nav>

  <main class="main-content">
    <div class="form-page">
      <div class="form-header">
        <h1 class="page-title">Chỉnh Sửa Sản Phẩm</h1>
        <p class="page-subtitle">Cập nhật thông tin sản phẩm <strong><%= product.name %></strong></p>
      </div>

      <% if (errors && errors.length > 0) { %>
        <div class="error-list">
          <strong>⚠ Vui lòng kiểm tra lại:</strong>
          <ul>
            <% errors.forEach(err => { %>
              <li><%= err %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <form action="/products/<%= product.id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="product-form" novalidate>
        <input type="hidden" name="_method" value="PUT" />
        <div class="form-grid">
          <div class="form-left">
            <div class="form-group">
              <label for="name" class="form-label">Tên sản phẩm <span class="required">*</span></label>
              <input
                type="text"
                id="name"
                name="name"
                value="<%= product.name || '' %>"
                class="form-control"
                placeholder="Nhập tên sản phẩm..."
                required
                maxlength="200"
              />
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="price" class="form-label">Giá (₫) <span class="required">*</span></label>
                <input
                  type="number"
                  id="price"
                  name="price"
                  value="<%= product.price || '' %>"
                  class="form-control"
                  placeholder="0"
                  min="0"
                  step="1000"
                  required
                />
              </div>
              <div class="form-group">
                <label for="unit_in_stock" class="form-label">Tồn kho <span class="required">*</span></label>
                <input
                  type="number"
                  id="unit_in_stock"
                  name="unit_in_stock"
                  value="<%= product.unit_in_stock || '' %>"
                  class="form-control"
                  placeholder="0"
                  min="0"
                  required
                />
              </div>
            </div>

            <div class="form-group">
              <label for="description" class="form-label">Mô tả</label>
              <textarea
                id="description"
                name="description"
                class="form-control"
                rows="4"
                placeholder="Mô tả ngắn về sản phẩm..."
                maxlength="1000"
              ><%= product.description || '' %></textarea>
            </div>
          </div>

          <div class="form-right">
            <div class="form-group">
              <label class="form-label">Hình ảnh sản phẩm</label>
              <div class="upload-zone" id="uploadZone">
                <% if (product.url_image) { %>
                  <div class="upload-preview" id="uploadPreview">
                    <img id="previewImg" src="<%= product.url_image %>" alt="<%= product.name %>" />
                    <button type="button" class="remove-preview" onclick="removePreview()">×</button>
                  </div>
                  <div class="upload-placeholder" id="uploadPlaceholder" style="display:none;">
                <% } else { %>
                  <div class="upload-preview" id="uploadPreview" style="display:none;">
                    <img id="previewImg" src="" alt="Preview" />
                    <button type="button" class="remove-preview" onclick="removePreview()">×</button>
                  </div>
                  <div class="upload-placeholder" id="uploadPlaceholder">
                <% } %>
                    <div class="upload-icon">📷</div>
                    <p class="upload-text">Kéo thả hoặc <strong>click để thay đổi ảnh</strong></p>
                    <p class="upload-hint">JPG, PNG, GIF, WEBP — tối đa 5MB</p>
                  </div>
                <input type="file" id="image" name="image" accept="image/*" class="file-input" />
              </div>
              <p class="upload-note">⚡ Để trống nếu không muốn thay đổi ảnh</p>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <a href="/" class="btn btn-cancel">Hủy</a>
          <a href="/products/<%= product.id %>" class="btn btn-secondary">Xem chi tiết</a>
          <button type="submit" class="btn btn-primary">💾 Cập nhật</button>
        </div>
      </form>
    </div>
  </main>

  <footer class="footer">
    <p>© 2024 ShopManager</p>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
