<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | ShopManager</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('../partials/flash') %>

  <nav class="navbar">
    <a href="/" class="nav-brand">
      <span class="brand-icon">◈</span>
      <span>ShopManager</span>
    </a>
    <div class="nav-actions">
      <a href="/" class="nav-link">← Danh sách</a>
      <a href="/products/<%= product.id %>/edit" class="btn btn-primary">✎ Chỉnh sửa</a>
    </div>
  </nav>

  <main class="main-content">
    <div class="detail-page">
      <div class="detail-card">
        <div class="detail-image-col">
          <% if (product.url_image) { %>
            <div class="detail-image-wrap">
              <img src="<%= product.url_image %>" alt="<%= product.name %>" class="detail-image" onerror="this.parentElement.innerHTML='<div class=no-image-large>📷</div>'" />
            </div>
          <% } else { %>
            <div class="no-image-large">📷</div>
          <% } %>
        </div>

        <div class="detail-info-col">
          <div class="detail-badge-row">
            <span class="stock-badge <%= product.unit_in_stock === 0 ? 'out-of-stock' : product.unit_in_stock < 10 ? 'low-stock' : 'in-stock' %>">
              <%= product.unit_in_stock === 0 ? 'Hết hàng' : product.unit_in_stock < 10 ? 'Còn ít' : 'Còn hàng' %>
            </span>
          </div>

          <h1 class="detail-title"><%= product.name %></h1>

          <div class="detail-price"><%= Number(product.price).toLocaleString('vi-VN') %>₫</div>

          <div class="detail-stats">
            <div class="stat-item">
              <span class="stat-label">Tồn kho</span>
              <span class="stat-value"><%= product.unit_in_stock %> sản phẩm</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">ID</span>
              <span class="stat-value stat-id"><%= product.id %></span>
            </div>
            <% if (product.createdAt) { %>
            <div class="stat-item">
              <span class="stat-label">Ngày tạo</span>
              <span class="stat-value"><%= new Date(product.createdAt).toLocaleDateString('vi-VN') %></span>
            </div>
            <% } %>
            <% if (product.updatedAt) { %>
            <div class="stat-item">
              <span class="stat-label">Cập nhật</span>
              <span class="stat-value"><%= new Date(product.updatedAt).toLocaleDateString('vi-VN') %></span>
            </div>
            <% } %>
          </div>

          <% if (product.description) { %>
            <div class="detail-description">
              <h3>Mô tả</h3>
              <p><%= product.description %></p>
            </div>
          <% } %>

          <div class="detail-actions">
            <a href="/" class="btn btn-cancel">← Quay lại</a>
            <a href="/products/<%= product.id %>/edit" class="btn btn-primary">✎ Chỉnh sửa</a>
            <button class="btn btn-danger" onclick="confirmDelete('<%= product.id %>', '<%= product.name.replace(/'/g, "\\'") %>')">🗑 Xóa</button>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Delete modal -->
  <div id="deleteModal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
      <div class="modal-icon">🗑️</div>
      <h3 class="modal-title">Xác nhận xóa</h3>
      <p class="modal-text">Bạn có chắc muốn xóa <strong id="deleteProductName"></strong>?</p>
      <div class="modal-actions">
        <button class="btn btn-cancel" onclick="closeModal()">Hủy</button>
        <form id="deleteForm" method="POST" style="display:inline;">
          <input type="hidden" name="_method" value="DELETE" />
          <button type="submit" class="btn btn-danger">Xóa</button>
        </form>
      </div>
    </div>
  </div>

  <footer class="footer">
    <p>© 2024 ShopManager</p>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
